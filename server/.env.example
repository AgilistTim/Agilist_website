OPENAI_API_KEY=sk-...
OPENAI_VECTOR_STORE_ID=vs_...
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview-2024-12-17
OPENAI_TEXT_MODEL=gpt-5-nano
OPENAI_REALTIME_VOICES=alloy,breeze,coral,marin,sage,verse
OPENAI_AGENT_INSTRUCTIONS_FILE=prompts/agent-system.txt
# Optional: use this instead of the file-based prompt if preferred
# OPENAI_AGENT_INSTRUCTIONS=You are Tim Robinson's AI consulting assistant...
PORT=4000

# Admin authentication
# Generate ADMIN_PASSWORD_HASH with: node scripts/generate-password-hash.mjs
ADMIN_PASSWORD_HASH=$2a$12$...
JWT_SECRET=replace-with-a-random-64-char-string
JWT_EXPIRY=2h

# GitHub integration (moved from client — DO NOT use PUBLIC_ prefix)
GITHUB_PAT=ghp_...
GITHUB_REPO_OWNER=AgilistTim
GITHUB_REPO_NAME=Agilist_website
GITHUB_BRANCH=main

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=https://www.agilist.co.uk,https://agilist.co.uk
