---
import '../index.css'
import '../App.css'
import ChatBot from '../components/ChatBot.jsx'
import CookieConsent from '../components/CookieConsent.jsx'

const {
  title,
  description,
  canonical,
  ogType = 'website',
  ogImage,
  jsonLd,
  noIndex = false
} = Astro.props

const metaTitle = title || 'Tim Robinson — Organisational Transformation & AI | agilist.co.uk'
const metaDescription =
  description ||
  '20+ years fixing how organisations work. Agile transformation, operating model design, and applied AI. Based in the UK.'

const baseUrl = Astro.site ?? new URL(Astro.url.origin)
const canonicalUrl = canonical || new URL(Astro.url.pathname, baseUrl).toString()
const ogImageUrl = ogImage || null
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{metaTitle}</title>
    <meta name="description" content={metaDescription} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={metaTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={metaTitle} />
    <meta name="twitter:description" content={metaDescription} />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap"
      rel="stylesheet"
    />

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <script is:inline>
      window.POSTHOG_KEY = import.meta.env.PUBLIC_POSTHOG_KEY;
      if (window.POSTHOG_KEY && localStorage.getItem('cookie_consent') === 'accepted') {
        var s = document.createElement('script');
        s.src = '/posthog-init.js';
        document.head.appendChild(s);
      }
    </script>

    <script>
      import { initAnalytics, trackPageView } from '../lib/analytics.js'
      // Init PostHog (React module path — handles dedup internally)
      initAnalytics()
      // Fire UTM-enriched page view on every page
      trackPageView()
    </script>

  </head>
  <body class="bg-[#0D0D0F] text-[#F4F4F5]">
    <slot />
    <ChatBot client:only="react" />
    <CookieConsent client:only="react" />
  </body>
</html>
