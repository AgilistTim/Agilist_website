---
import BaseLayout from '../layouts/BaseLayout.astro'
import { AdminBlogUpload } from '../components/AdminBlogUpload.jsx'

const API_BASE_URL = import.meta.env.PUBLIC_API_BASE_URL || import.meta.env.VITE_API_BASE_URL || 'http://localhost:4000'
---
<BaseLayout
  title="Admin Dashboard | Tim Robinson AI Consulting"
  description="Admin dashboard for managing blog content."
>
  <div class="min-h-screen bg-[#0D0D0F] text-[#F4F4F5] py-12">
    <div class="max-w-4xl mx-auto px-4">
      <div class="mb-8">
        <h1 class="text-3xl font-bold text-white mb-2">Admin Dashboard</h1>
        <p class="text-[#A1A1AA]">Manage blog posts and RAG vector store content</p>
      </div>

      <AdminBlogUpload client:only="react" apiBaseUrl={API_BASE_URL} />

      <div class="mt-8 p-4 bg-[#16161A] border border-[#2A2A35] rounded-lg">
        <h2 class="font-semibold text-white mb-2">Batch Upload Existing Posts</h2>
        <p class="text-sm text-[#A1A1AA] mb-3">
          To upload all existing blog posts to the vector store, run this command in the server directory:
        </p>
        <code class="block bg-[#0D0D0F] p-3 rounded text-sm text-[#A78BFA] font-mono">
          node scripts/upload-blogs-to-vectorstore.js
        </code>
      </div>
    </div>
  </div>
</BaseLayout>
