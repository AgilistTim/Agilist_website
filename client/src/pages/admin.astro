---
import BaseLayout from '../layouts/BaseLayout.astro'
import AdminPage from '../components/AdminPage.jsx'

const API_BASE_URL = import.meta.env.PUBLIC_API_BASE_URL || import.meta.env.VITE_API_BASE_URL || 'http://localhost:4000'
---
<BaseLayout
  title="Admin Dashboard | Tim Robinson AI Consulting"
  description="Admin dashboard for managing blog content."
  noIndex={true}
>
  <AdminPage client:only="react" apiBaseUrl={API_BASE_URL} />
</BaseLayout>
