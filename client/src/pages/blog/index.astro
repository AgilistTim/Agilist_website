---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getCollection } from 'astro:content'

const posts = await getCollection('blog', ({ data }) => !data.draft)
const sortedPosts = posts.sort((a, b) => b.data.date - a.data.date)

const canonical = new URL('/blog', Astro.site ?? Astro.url.origin).toString()

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'Tim Robinson — AI Foresight & Transformation Blog',
  url: canonical
}

const dateFormatter = new Intl.DateTimeFormat('en-GB', {
  day: '2-digit',
  month: 'long',
  year: 'numeric'
})
---
<BaseLayout
  title="Blog | Tim Robinson — AI Foresight & Transformation"
  description="Insights on AI foresight, venture studio execution, and transformation strategy."
  canonical={canonical}
  ogType="website"
  jsonLd={jsonLd}
>
  <div class="min-h-screen bg-[#0D0D0F] text-[#F4F4F5]">
    <nav class="fixed top-0 w-full bg-[#0D0D0F]/95 backdrop-blur-sm z-50 border-b border-[#2A2A35]">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-wrap items-center justify-between gap-4 py-4">
          <a href="/" class="text-2xl font-bold text-white">Tim Robinson</a>
          <div class="hidden md:flex space-x-8 text-sm">
            <a href="/#track-record" class="hover:text-white transition-colors">Track record</a>
            <a href="/#projects" class="hover:text-white transition-colors">Projects</a>
            <a href="/#assistant" class="hover:text-white transition-colors">AI assistant</a>
            <a href="/blog" class="text-[#A78BFA]">Blog</a>
            <a href="/#contact" class="hover:text-white transition-colors">Contact</a>
          </div>
          <a
            href="https://tanagra.youcanbook.me"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center rounded-md bg-gradient-to-r from-[#7C3AED] to-[#9F67FA] px-4 py-2 text-sm font-semibold text-white"
          >
            Start a conversation
          </a>
        </div>
      </div>
    </nav>

    <main class="pt-28 pb-12 sm:pt-32 sm:pb-16">
      <section class="pb-12 sm:pb-16">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
          <p class="text-sm uppercase tracking-[0.35em] text-[#A78BFA]">Blog</p>
          <h1 class="text-4xl sm:text-5xl font-bold mt-4">Insights on AI foresight and transformation</h1>
          <p class="text-base sm:text-lg text-[#A1A1AA] mt-4 max-w-3xl">
            Field notes on venture studio execution, regulated-sector AI, and the signals that matter next.
          </p>
        </div>
      </section>

      <section class="pb-16 sm:pb-24">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="grid gap-6">
            {sortedPosts.map((post) => (
              <article class="rounded-2xl border border-[#2A2A35] bg-[#16161A] p-6 sm:p-8">
                <div class="flex flex-wrap items-center gap-3 text-xs uppercase tracking-wide text-[#A1A1AA]">
                  <span>{dateFormatter.format(post.data.date)}</span>
                  {post.data.tags?.length ? (
                    <div class="flex flex-wrap gap-2">
                      {post.data.tags.map((tag) => (
                        <span class="rounded-full bg-[#0D0D0F] px-3 py-1 text-[11px] text-[#A78BFA]">{tag}</span>
                      ))}
                    </div>
                  ) : null}
                </div>
                <h2 class="text-2xl sm:text-3xl font-semibold mt-4">
                  <a class="hover:text-[#A78BFA] transition-colors" href={`/blog/${post.slug}`}>
                    {post.data.title}
                  </a>
                </h2>
                <p class="text-[#A1A1AA] mt-3 leading-relaxed">{post.data.summary}</p>
                <a
                  class="inline-flex items-center gap-2 text-[#A78BFA] hover:text-white mt-5 text-sm"
                  href={`/blog/${post.slug}`}
                >
                  Read the full article
                  <span aria-hidden="true">-&gt;</span>
                </a>
              </article>
            ))}
          </div>
        </div>
      </section>
    </main>

    <footer class="border-t border-[#2A2A35] py-12">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-3 gap-8">
          <div>
            <div class="text-2xl font-bold text-white mb-4">Tim Robinson</div>
            <p class="text-[#A1A1AA]">AI Foresight & Venture Studio</p>
          </div>
          <div>
            <h3 class="font-semibold mb-4">Quick Links</h3>
            <div class="space-y-2">
              <a href="/#track-record" class="block text-[#A1A1AA] hover:text-white transition-colors">Track record</a>
              <a href="/#projects" class="block text-[#A1A1AA] hover:text-white transition-colors">Projects</a>
              <a href="/blog" class="block text-[#A1A1AA] hover:text-white transition-colors">Blog</a>
            </div>
          </div>
          <div>
            <h3 class="font-semibold mb-4">Get in Touch</h3>
            <a
              href="https://tanagra.youcanbook.me"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center rounded-md bg-gradient-to-r from-[#7C3AED] to-[#9F67FA] px-4 py-2 text-sm font-semibold text-white w-full"
            >
              Start a Conversation
            </a>
          </div>
        </div>
        <div class="border-t border-[#2A2A35] mt-8 pt-8 text-center text-[#A1A1AA]">
          <p>&copy; 2026 Tim Robinson. All rights reserved.</p>
        </div>
      </div>
    </footer>
  </div>
</BaseLayout>
