---
import BaseLayout from '../layouts/BaseLayout.astro'
import App from '../App.jsx'
import { getCollection } from 'astro:content'

const posts = await getCollection('blog', ({ data }) => !data.draft)
const latestPosts = posts
  .sort((a, b) => b.data.date - a.data.date)
  .slice(0, 3)
  .map(({ slug, data }) => ({
    slug,
    title: data.title,
    date: data.date.toISOString(),
    summary: data.summary,
    tags: data.tags ?? []
  }))

const canonical = new URL('/', Astro.site ?? Astro.url.origin).toString()

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      name: 'Tim Robinson',
      url: canonical,
      description:
        'Organisational transformation consultant and AI practitioner with 20+ years experience. Helps organisations redesign how work, decisions, and learning flow.',
      jobTitle: 'Transformation Consultant & AI Practitioner',
      knowsAbout: [
        'Organisational transformation',
        'Agile delivery',
        'Operating model design',
        'Applied AI',
        'AI governance',
        'Product operations',
        'Systems thinking'
      ],
      sameAs: ['https://www.linkedin.com/in/tim-robinson-agilist/']
    },
    {
      '@type': 'Organization',
      name: 'Agilist',
      url: canonical,
      description: 'Organisational transformation and applied AI consultancy based in the United Kingdom.',
      founder: {
        '@type': 'Person',
        name: 'Tim Robinson'
      },
      sameAs: ['https://www.linkedin.com/in/tim-robinson-agilist/']
    },
    {
      '@type': 'WebSite',
      name: 'Agilist',
      url: canonical,
      potentialAction: {
        '@type': 'SearchAction',
        target: `${canonical}?q={search_term_string}`,
        'query-input': 'required name=search_term_string'
      }
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: 'What kind of organisations does Tim Robinson work with?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Tim works with organisations where progress has slowed — not because people aren\'t capable, but because the system has reached its limits. From large enterprises whose transformation has stalled to smaller organisations making AI adoption stick.'
          }
        },
        {
          '@type': 'Question',
          name: 'How is Tim Robinson different from a management consultancy?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Tim diagnoses what\'s structurally stuck rather than selling frameworks. He identifies where friction is structural rather than personal, and redesigns how work, decisions, and learning actually flow. Unlike most consultants in this space, he also builds AI products — so the advice comes from practice, not theory.'
          }
        },
        {
          '@type': 'Question',
          name: 'What is organisational transformation consulting?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Organisational transformation consulting helps businesses redesign how they work when progress has stalled. It addresses structural constraints — information flow, decision latency, feedback loop breakdowns — rather than blaming people or adding more process.'
          }
        },
        {
          '@type': 'Question',
          name: 'What does a typical engagement with Tim Robinson look like?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'It starts with a conversation. From there it might be a short diagnostic, a coaching engagement, a training programme, or an ongoing advisory relationship. Tim works on day-rate or fixed-price outcomes, and starts with diagnosis — not solutions.'
          }
        }
      ]
    }
  ]
}
---
<BaseLayout
  title="Tim Robinson — Organisational Transformation & AI | agilist.co.uk"
  description="20+ years fixing how organisations work. Agile transformation, operating model design, and applied AI. Based in the UK."
  canonical={canonical}
  ogType="website"
  jsonLd={jsonLd}
>
  <App latestPosts={latestPosts} client:only="react" />
</BaseLayout>
